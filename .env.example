# =============================================================================
# Beast environment
#
# Three ways to run, smallest footprint first:
#
#   1. Demo mode (zero external keys). Set NEXT_PUBLIC_DEMO_MODE=1 and point
#      DATABASE_URL at any Postgres with pgvector (docker compose up gives you
#      one). Auth is bypassed to a seeded founder and every paid call is off.
#      This is exactly what the public demo runs on.
#
#   2. Real auth + database. Fill the Supabase block and DATABASE_URL. The app
#      boots fully; agent runs still need the Anthropic block in section 3.
#
#   3. Everything. Add the optional blocks for embeddings, background workers,
#      billing, file uploads, and publishing connectors.
#
# Copy to .env.local and fill what you need.
# =============================================================================

# --- 1. Demo mode -----------------------------------------------------------
# "1" bypasses Supabase auth and disables all paid/external calls.
NEXT_PUBLIC_DEMO_MODE=

# Any Postgres with the pgvector extension. `docker compose up -d` exposes one:
DATABASE_URL=postgresql://postgres:beast@localhost:5544/beast

# --- 2. Real auth + database (Supabase) -------------------------------------
# Not needed in demo mode. Create a free project at supabase.com.
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=
# For a Supabase database, set DATABASE_URL above to its pooled connection string.

# --- 3. Agent runtime (live agents) -----------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# Embeddings for semantic memory + knowledge search.
GEMINI_API_KEY=AIza...

# --- 4. Background workers (Trigger.dev) ------------------------------------
# Runs the agent loop, scheduled check-ins, drift detection, auto-publish.
TRIGGER_SECRET_KEY=tr_dev_...
TRIGGER_PROJECT_ID=proj_...
# Used for links in worker-sent Slack/email notifications.
APP_URL=

# --- 5. Agent tools (optional, degrade gracefully) --------------------------
SERPER_API_KEY=
FIRECRAWL_API_KEY=
UNSTRUCTURED_API_KEY=

# --- 6. File uploads (Cloudflare R2, optional) ------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=beast-files

# --- 7. Billing (Stripe, optional) ------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PRICE_BUSINESS=price_...

# --- 8. Email (Resend, optional) --------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=Beast <updates@example.com>

# --- 9. Publishing + Slack connectors (optional) ----------------------------
# 64-char hex key that encrypts stored OAuth tokens (openssl rand -hex 32).
CONNECTOR_ENCRYPTION_KEY=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TWITTER_API_KEY=
TWITTER_API_SECRET=
WORDPRESS_CLIENT_ID=
WORDPRESS_CLIENT_SECRET=

# --- 10. Deploy -------------------------------------------------------------
# Public URL of the app, set after the first Vercel deploy.
NEXT_PUBLIC_APP_URL=
# VERCEL_URL is injected automatically by Vercel during build; do not set it.
