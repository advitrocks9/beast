{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@beast/db": ["../../packages/db/src/index.ts"],
      "@beast/db/*": ["../../packages/db/src/*"],
      "@beast/shared": ["../../packages/shared/src/index.ts"],
      "@beast/shared/*": ["../../packages/shared/src/*"],
      "@beast/ui": ["../../packages/ui/src/index.ts"],
      "@beast/ui/*": ["../../packages/ui/src/*"],
      "@beast/ai": ["../../packages/ai/src/index.ts"],
      "@beast/ai/*": ["../../packages/ai/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
